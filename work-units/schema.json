{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/yokoyama-lab/analysis-at-home/work-units/schema.json",
  "title": "analysis@home work unit",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "statement_informal", "claim_kind", "targets", "prompt_template", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Stable kebab-case identifier; must match the directory name."
    },
    "title": { "type": "string", "minLength": 1 },
    "statement_informal": { "type": "string", "minLength": 1 },
    "domain": { "type": "string" },
    "claim_kind": {
      "type": "string",
      "enum": ["correctness", "complexity", "closed-form"]
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "enum": ["rocq", "lean", "agda", "isabelle"] }
    },
    "prompt_template": { "type": "string" },
    "expected_theorem": {
      "type": "string",
      "description": "Name of the identifier a submission must prove with no axioms (checked by the verifier via Print Assumptions). For now a single canonical name shared across backends."
    },
    "cost_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "counts"],
      "description": "How a step is costed. Required for complexity/closed-form claims.",
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["func-ops", "while-ops", "riscv", "llvm"],
          "description": "func-ops: operation count on a functional core; while-ops: operation count on a WHILE imperative core; riscv/llvm: concrete-cost layers."
        },
        "counts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Designated operations counted as unit cost, e.g. [\"comparison\"], [\"key-comparison\"], [\"multiplication\"]."
        },
        "notes": { "type": "string" }
      }
    },
    "references": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "enum": ["open", "submitted", "verified"]
      }
    }
  },
  "if": {
    "properties": {
      "claim_kind": { "enum": ["complexity", "closed-form"] }
    }
  },
  "then": {
    "required": ["cost_model"]
  }
}
